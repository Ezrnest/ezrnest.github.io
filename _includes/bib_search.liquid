{% if site.bib_search %}
  {% assign current_lang = page.lang | default: site.lang %}
  {% assign t = site.data.i18n[current_lang] %}
  <script src="{{ '/assets/js/bibsearch.js' | relative_url | bust_file_cache }}" type="module"></script>
  <input
    type="text"
    id="bibsearch"
    spellcheck="false"
    autocomplete="off"
    class="search bibsearch-form-input"
    placeholder="{{ t.bib_search_placeholder | default: 'Type to filter publications' }}"
  >
{% endif %}
